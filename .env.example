# Django
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL recommended for production; SQLite works for demo)
DATABASE_URL=

# Email
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@example.com

# AI image generation (optional; enables the ai_media app)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# Social login (optional; enables Google OAuth)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Admin branding
CMS_SITE_TITLE=Resonans CMS
CMS_SITE_HEADER=Resonans

# Celery (optional; required for background auto-linking task)
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
